---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
  <div class="w-12 h-12 rounded-xl bg-action-light flex items-center justify-center text-action" aria-hidden="true">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-base font-semibold text-slate-900 mt-4">{title}</h3>
  <p class="text-sm text-slate-600 mt-2 leading-relaxed">{description}</p>
</div>
