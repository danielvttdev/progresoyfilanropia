---
import { mainNav } from '../data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 bg-white/80 backdrop-blur-md border-b border-transparent"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group" aria-label="Ir al inicio">
      <img
        src="/images/logo progresoyfilantropia.png"
        alt="Logo Progreso y Filantropía"
        class="h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-102"
      />
      <span class="hidden sm:block text-sm font-bold text-slate-900 tracking-tight">
        Progreso y Filantropía
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Navegación principal">
      {mainNav.map((item) => (
        item.isButton ? (
          <a
            href={item.href}
            class="ml-3 inline-flex items-center gap-2 px-5 py-2 bg-action text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-action-hover hover:shadow-md active:bg-action-active transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
            {item.label}
          </a>
        ) : (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-lg transition-colors duration-200',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-slate-900 bg-slate-100'
                : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-2 lg:hidden">
      <a
        href="/donar/"
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-action text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-action-hover transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
        Donar
      </a>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-slate-100 transition-colors"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-700 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-16 bg-white z-40 transform translate-x-full transition-transform duration-300 ease-in-out"
    aria-hidden="true"
  >
    <nav class="p-6 flex flex-col gap-1" aria-label="Navegación móvil">
      {mainNav.filter(item => !item.isButton).map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-3 text-base font-medium rounded-lg transition-colors',
            currentPath === item.href
              ? 'text-slate-900 bg-slate-100'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
