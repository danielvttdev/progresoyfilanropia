---
import { mainNav } from '../data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-500 ease-out"
>
  <div class="absolute inset-0 bg-white/0 backdrop-blur-0 border-b border-transparent transition-all duration-500" id="header-bg"></div>

  <div class="relative max-w-7xl mx-auto px-6 h-18 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Ir al inicio">
      <div class="relative">
        <div class="absolute inset-0 bg-action/0 rounded-xl transition-all duration-300 group-hover:bg-action/10 group-hover:scale-110" aria-hidden="true"></div>
        <img
          src="/images/logo progresoyfilantropia.png"
          alt="Logo Progreso y Filantropía"
          class="relative h-10 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
        />
      </div>
      <div class="hidden sm:flex flex-col">
        <span class="text-sm font-bold font-display text-slate-900 tracking-tight leading-none">
          Progreso y Filantropía
        </span>
        <span class="text-[10px] font-medium text-slate-400 tracking-wide leading-none mt-0.5">
          Fundación Social
        </span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-0.5" aria-label="Navegación principal">
      {mainNav.filter(item => !item.isButton).map((item) => (
        <a
          href={item.href}
          class:list={[
            'relative px-3 py-2 text-[13px] font-semibold tracking-wide rounded-lg transition-all duration-300',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-slate-900'
              : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50'
          ]}
          aria-current={currentPath === item.href ? 'page' : undefined}
        >
          {item.label}
          {(currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) && (
            <span class="absolute bottom-0.5 left-1/2 -translate-x-1/2 w-5 h-0.5 bg-action rounded-full" aria-hidden="true"></span>
          )}
        </a>
      ))}

      <!-- Divider -->
      <div class="w-px h-5 bg-slate-200 mx-2" aria-hidden="true"></div>

      <!-- Social icons -->
      <div class="flex items-center gap-1">
        <a href="https://api.whatsapp.com/send/?phone=5491132436095&text&type=phone_number&app_absent=0&utm_source=ig" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-emerald-500 hover:bg-emerald-50 transition-all duration-200" aria-label="WhatsApp">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.202-1.362a9.92 9.92 0 004.805 1.24c5.506 0 9.99-4.479 9.999-9.986.004-2.668-1.033-5.176-2.927-7.072C17.186 2.924 14.68 2.004 12.012 2zm5.72 13.916c-.244.69-1.42 1.348-1.94 1.4-.48.05-1.11.23-3.23-.65-2.73-1.13-4.47-3.9-4.61-4.08-.13-.19-1.07-1.42-1.07-2.71 0-1.29.67-1.92.91-2.18.24-.26.54-.32.72-.32.18 0 .36 0 .52.01.17 0 .4.06.6.53.22.52.73 1.79.8 1.93.07.14.11.3.01.49-.1.2-.15.31-.3.49-.15.18-.32.39-.45.52-.15.15-.31.32-.13.62.18.3.8 1.31 1.71 2.12.83.74 1.52.96 1.83 1.12.3.16.48.14.66-.06.18-.21.78-.91.99-1.22.2-.3.42-.26.71-.15.29.11 1.86.88 2.18 1.04.32.16.54.24.62.38.08.14.08.81-.16 1.5z"/></svg>
        </a>
        <a href="https://www.instagram.com/progresoyfilantropia/" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-pink-500 hover:bg-pink-50 transition-all duration-200" aria-label="Instagram">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.youtube.com/@ar.ProgresoyFilantrop%C3%ADaSocial" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-red-500 hover:bg-red-50 transition-all duration-200" aria-label="YouTube">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 00-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 002.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 002.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>

      <!-- Donar CTA -->
      {mainNav.filter(item => item.isButton).map((item) => (
        <a
          href={item.href}
          class="ml-2 inline-flex items-center gap-2 px-5 py-2.5 bg-action text-white text-sm font-bold rounded-xl shadow-md shadow-action/20 hover:bg-action-hover hover:shadow-lg hover:shadow-action/25 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile: Donar + Hamburger -->
    <div class="flex items-center gap-2 lg:hidden">
      <a
        href="/donar/"
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-action text-white text-sm font-bold rounded-xl shadow-sm hover:bg-action-hover transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
        Donar
      </a>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-colors"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-700 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-18 bg-white z-40 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
    aria-hidden="true"
  >
    <nav class="flex-1 p-6 flex flex-col gap-1 overflow-y-auto" aria-label="Navegación móvil">
      {mainNav.filter(item => !item.isButton).map((item) => (
        <a
          href={item.href}
          class:list={[
            'px-4 py-3.5 text-base font-semibold rounded-xl transition-all duration-200',
            currentPath === item.href
              ? 'text-slate-900 bg-slate-50'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="border-t border-slate-100 p-6 bg-slate-50/50">
      <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 block mb-4">Nuestras redes sociales</span>
      <div class="flex items-center gap-3">
        <a href="https://api.whatsapp.com/send/?phone=5491132436095&text&type=phone_number&app_absent=0&utm_source=ig" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-500 hover:text-emerald-500 hover:bg-emerald-50 hover:border-emerald-200 transition-all duration-200">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.202-1.362a9.92 9.92 0 004.805 1.24c5.506 0 9.99-4.479 9.999-9.986.004-2.668-1.033-5.176-2.927-7.072C17.186 2.924 14.68 2.004 12.012 2zm5.72 13.916c-.244.69-1.42 1.348-1.94 1.4-.48.05-1.11.23-3.23-.65-2.73-1.13-4.47-3.9-4.61-4.08-.13-.19-1.07-1.42-1.07-2.71 0-1.29.67-1.92.91-2.18.24-.26.54-.32.72-.32.18 0 .36 0 .52.01.17 0 .4.06.6.53.22.52.73 1.79.8 1.93.07.14.11.3.01.49-.1.2-.15.31-.3.49-.15.18-.32.39-.45.52-.15.15-.31.32-.13.62.18.3.8 1.31 1.71 2.12.83.74 1.52.96 1.83 1.12.3.16.48.14.66-.06.18-.21.78-.91.99-1.22.2-.3.42-.26.71-.15.29.11 1.86.88 2.18 1.04.32.16.54.24.62.38.08.14.08.81-.16 1.5z"/></svg>
        </a>
        <a href="https://www.instagram.com/progresoyfilantropia/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-500 hover:text-pink-500 hover:bg-pink-50 hover:border-pink-200 transition-all duration-200">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.whatsapp.com/channel/0029Vb68Wb96rsQvTiUJnh0Q" target="_blank" rel="noopener noreferrer" aria-label="Canal de WhatsApp" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-500 hover:text-emerald-500 hover:bg-emerald-50 hover:border-emerald-200 transition-all duration-200">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12c0 2.17.7 4.19 1.89 5.83L2.5 22l4.31-1.3A9.94 9.94 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"/></svg>
        </a>
        <a href="https://www.youtube.com/@ar.ProgresoyFilantrop%C3%ADaSocial" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-500 hover:text-red-500 hover:bg-red-50 hover:border-red-200 transition-all duration-200">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 00-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 002.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 002.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>