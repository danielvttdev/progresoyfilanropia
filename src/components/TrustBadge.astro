---
interface TrustItem {
  label: string;
  icon: string;
}

interface Props {
  items: TrustItem[];
}

const { items } = Astro.props;
---

<div class="flex flex-wrap justify-center gap-6 md:gap-10 py-2">
  {items.map((item) => (
    <div class="flex items-center gap-2.5 text-slate-600 bg-slate-50/50 px-4 py-2 rounded-full border border-slate-100 hover:bg-slate-50 transition-colors duration-200">
      <span class="text-lg" aria-hidden="true">{item.icon}</span>
      <span class="text-xs md:text-sm font-bold tracking-wider uppercase text-slate-800">{item.label}</span>
    </div>
  ))}
</div>
