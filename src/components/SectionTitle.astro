---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  accentLine?: boolean;
}

const {
  title,
  subtitle,
  align = 'center',
  accentLine = false,
} = Astro.props;
---

<div class={`mb-12 ${align === 'center' ? 'text-center' : 'text-left'}`}>
  {accentLine && (
    <div class={`w-12 h-1 bg-action rounded-full mb-6 ${align === 'center' ? 'mx-auto' : ''}`}></div>
  )}
  <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">
    {title}
  </h2>
  {subtitle && (
    <p class={`text-lg text-slate-600 mt-4 max-w-2xl ${align === 'center' ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
</div>
