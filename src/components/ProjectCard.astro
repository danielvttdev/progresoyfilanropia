---
interface Props {
  title: string;
  description: string;
  category: string;
  status: string;
  href?: string;
  image?: string;
}

const { title, description, category, status, href = '/proyectos/', image } = Astro.props;
---

<article class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
  <!-- Image container -->
  <div class="aspect-video bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center relative overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500"
      />
    ) : (
      <>
        <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <svg xmlns="http://www.w3.org/2500/svg" class="w-12 h-12 text-slate-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </>
    )}
  </div>

  <div class="p-6 flex flex-col flex-grow">
    <!-- Badges -->
    <div class="flex items-center gap-2 mb-4">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-action-light text-action">
        {category}
      </span>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700">
        {status}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-lg font-bold text-slate-900 leading-tight group-hover:text-action transition-colors duration-200 mb-2">
      {href ? (
        <a href={href}>{title}</a>
      ) : (
        title
      )}
    </h3>

    <!-- Description -->
    <p class="text-sm text-slate-600 line-clamp-3 mb-6 flex-grow leading-relaxed">
      {description}
    </p>

    <!-- Link -->
    <div class="mt-auto">
      <a
        href={href}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-action hover:text-action-hover transition-colors group-hover:underline"
      >
        Ver proyecto
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</article>
