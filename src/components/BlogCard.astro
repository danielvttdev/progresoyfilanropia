---
interface Props {
  title: string;
  description: string;
  category: string;
  date: Date;
  slug: string;
  author?: string;
  image?: string;
}

const { title, description, category, date, slug, author, image } = Astro.props;

const formattedDate = date.toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group relative bg-white border border-slate-200/60 rounded-2xl overflow-hidden card-hover flex flex-col h-full">
  <!-- Image -->
  <div class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-slate-100 to-slate-50">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-[1.06] transition-transform duration-700"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="flex items-center justify-center w-full h-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-slate-200 group-hover:text-action/20 group-hover:scale-110 transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2-2m2 2a2 2 0 11-4 0m4 0v6a2 2 0 01-2 2H9" />
        </svg>
      </div>
    )}
    <!-- Hover gradient -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/15 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
    <!-- Category badge -->
    <div class="absolute top-3 left-3 z-10">
      <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-[10px] font-bold bg-white/90 backdrop-blur-sm text-action uppercase tracking-wider shadow-sm">
        {category}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-grow">
    <!-- Date -->
    <time datetime={date.toISOString()} class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-400 mb-3">
      {formattedDate}
    </time>

    <h3 class="text-lg font-bold font-display text-slate-900 leading-tight group-hover:text-action transition-colors duration-300 mb-2">
      <a href={`/blog/${slug}/`} class="after:absolute after:inset-0">{title}</a>
    </h3>

    <p class="text-sm text-slate-500 line-clamp-2 mb-auto leading-relaxed">
      {description}
    </p>

    <div class="flex items-center justify-between pt-5 mt-6 border-t border-slate-100/80">
      {author && (
        <span class="text-xs text-slate-400 font-medium">
          Por {author}
        </span>
      )}
      <a
        href={`/blog/${slug}/`}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-action hover:text-action-hover transition-colors duration-200"
      >
        Leer más
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</article>