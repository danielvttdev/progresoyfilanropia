---
interface Props {
  title: string;
  description: string;
  category: string;
  date: Date;
  slug: string;
  author?: string;
}

const { title, description, category, date, slug, author } = Astro.props;

const formattedDate = date.toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
  <!-- Image placeholder (gradient) -->
  <div class="aspect-video bg-gradient-to-br from-blue-50 to-slate-100 flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-slate-300 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2-2m2 2a2 2 0 11-4 0m4 0v6a2 2 0 01-2 2H9" />
    </svg>
  </div>

  <div class="p-6 flex flex-col flex-grow">
    <!-- Meta info -->
    <div class="flex items-center gap-3 mb-3 text-xs">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full font-semibold bg-action-light text-action uppercase tracking-wider text-[10px]">
        {category}
      </span>
      <time datetime={date.toISOString()} class="text-slate-500 font-medium">
        {formattedDate}
      </time>
    </div>

    <!-- Title -->
    <h3 class="text-lg font-bold text-slate-900 leading-tight group-hover:text-action transition-colors duration-200 mb-2">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>

    <!-- Description -->
    <p class="text-sm text-slate-600 line-clamp-2 mb-6 leading-relaxed flex-grow">
      {description}
    </p>

    <!-- Author & Footer -->
    <div class="mt-auto flex items-center justify-between pt-4 border-t border-slate-100">
      {author && (
        <span class="text-xs text-slate-500 font-medium">
          Por {author}
        </span>
      )}
      <a
        href={`/blog/${slug}/`}
        class="inline-flex items-center gap-1 text-sm font-semibold text-action hover:text-action-hover transition-colors"
      >
        Leer más
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</article>
