---
interface Props {
  title: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  ctaTertiary?: { label: string; href: string };
  variant?: 'home' | 'page';
  showPattern?: boolean;
}

const {
  title,
  subtitle,
  ctaPrimary,
  ctaSecondary,
  ctaTertiary,
  variant = 'page',
  showPattern = false,
} = Astro.props;
---

{variant === 'home' ? (
  <section class="relative overflow-hidden bg-institutional text-white" role="banner">
    <!-- Layered cinematic background -->
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0 bg-cover bg-center opacity-40 scale-105" style="background-image: url('/images/home-hero-bg.png');"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-slate-950/80 via-slate-950/60 to-institutional/90"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:72px_72px]"></div>
      <!-- Atmospheric orbs — monochrome -->
      <div class="absolute -top-1/4 -left-[10%] w-[600px] h-[600px] rounded-full bg-white/[0.04] blur-[160px]"></div>
      <div class="absolute -bottom-1/4 -right-[5%] w-[500px] h-[500px] rounded-full bg-white/[0.03] blur-[140px]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-36 pb-20 md:pt-44 md:pb-28 lg:pt-52 lg:pb-36">
      <!-- Overline -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[11px] font-bold uppercase tracking-[0.25em] bg-white/[0.06] backdrop-blur-xl text-white/70 border border-white/[0.08] mb-10 animate-fade-in-up">
        <span class="flex h-1.5 w-1.5 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
        </span>
        Tercer Sector &middot; Apartidario
      </div>

      <!-- Headline -->
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] font-extrabold font-display text-white tracking-tight leading-[1.05] max-w-5xl drop-shadow-md animate-fade-in-up animation-delay-100"
        set:html={title.replace('ciudadanía activa', '<em class="not-italic font-serif">ciudadanía activa</em>')}
      />

      {subtitle && (
        <p class="text-lg md:text-xl text-white/60 mt-8 max-w-3xl mx-auto leading-relaxed font-light animate-fade-in-up animation-delay-200">
          {subtitle}
        </p>
      )}

      <!-- CTAs -->
      {(ctaPrimary || ctaSecondary || ctaTertiary) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12 animate-fade-in-up animation-delay-300">
          {ctaPrimary && (
            <a
              href={ctaPrimary.href}
              class="group inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-action text-white text-sm font-bold rounded-xl shadow-lg hover:bg-action-hover hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
            >
              {ctaPrimary.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              class="group inline-flex items-center justify-center gap-2.5 px-8 py-4 border border-white/20 bg-white/[0.08] backdrop-blur-sm text-white text-sm font-semibold rounded-xl hover:bg-white/[0.15] hover:border-white/40 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
              {ctaSecondary.label}
            </a>
          )}
          {ctaTertiary && (
            <a
              href={ctaTertiary.href}
              class="group inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/[0.08] bg-transparent text-white/70 text-sm font-semibold rounded-xl hover:bg-white/[0.05] hover:text-white hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
            >
              {ctaTertiary.label}
            </a>
          )}
        </div>
      )}

      <!-- Metrics -->
      <div class="animate-fade-in-up animation-delay-400">
        <slot />
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 animate-fade-in animation-delay-600">
      <span class="text-[10px] font-bold tracking-[0.25em] text-white/40 uppercase">Descubrí</span>
      <div class="w-5 h-9 border-2 border-white/20 rounded-full flex justify-center pt-1.5">
        <div class="w-1 h-2 bg-white/50 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>
) : (
  <section class="relative overflow-hidden bg-institutional border-b border-slate-950 py-16 md:py-24 text-white">
    <div class="absolute inset-0 bg-cover bg-center mix-blend-overlay opacity-40 pointer-events-none" style="background-image: url('/images/hero-bg.png');" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-institutional via-institutional/40 to-transparent opacity-90 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-[-20%] right-[-10%] w-[300px] h-[300px] rounded-full bg-white/[0.03] blur-[100px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-display text-white tracking-tight leading-tight max-w-4xl mx-auto drop-shadow-md">
        {title}
      </h1>

      {subtitle && (
        <p class="text-base md:text-lg text-white/60 mt-4 max-w-2xl mx-auto leading-relaxed font-light">
          {subtitle}
        </p>
      )}

      {(ctaPrimary || ctaSecondary) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          {ctaPrimary && (
            <a
              href={ctaPrimary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-action text-white text-sm font-bold rounded-xl shadow-lg hover:bg-action-hover active:bg-action-active transition-all duration-300"
            >
              {ctaPrimary.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white text-sm font-semibold rounded-xl hover:bg-white/10 transition-all duration-200"
            >
              {ctaSecondary.label}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}