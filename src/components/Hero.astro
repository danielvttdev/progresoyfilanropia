---
interface Props {
  title: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  ctaTertiary?: { label: string; href: string };
  variant?: 'home' | 'page';
  showPattern?: boolean;
}

const {
  title,
  subtitle,
  ctaPrimary,
  ctaSecondary,
  ctaTertiary,
  variant = 'page',
  showPattern = false,
} = Astro.props;
---

{variant === 'home' ? (
  <section class="relative overflow-hidden bg-institutional border-b border-slate-950 py-28 md:py-36 lg:py-44 text-white text-center">
    <!-- Full-screen background image representing community active collaboration -->
    <div class="absolute inset-0 bg-cover bg-center opacity-60 pointer-events-none" style="background-image: url('/images/home-hero-bg.png');" aria-hidden="true"></div>
    
    <!-- Modern technical grid background overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff03_1px,transparent_1px),linear-gradient(to_bottom,#ffffff03_1px,transparent_1px)] bg-[size:4rem_4rem] pointer-events-none" aria-hidden="true"></div>
    
    <!-- Premium ambient glowing orbs -->
    <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[60%] rounded-full bg-blue-500/10 blur-[120px] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[50%] rounded-full bg-indigo-500/10 blur-[100px] pointer-events-none" aria-hidden="true"></div>
    
    <!-- Dark gradient overlay for extreme readability & accessibility, optimized to showcase the warm image details -->
    <div class="absolute inset-0 bg-gradient-to-b from-slate-950/60 via-slate-950/45 to-institutional pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <!-- Animated Premium Pill Tag -->
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-xs font-semibold bg-white/5 backdrop-blur-md text-slate-200 border border-white/10 tracking-widest uppercase mb-8 animate-fade-in-up">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
        </span>
        Tercer Sector • Apartidario
      </div>

      <!-- Majestic Typographic Title with Gradient Highlight -->
      <h1 
        class="text-4xl md:text-5xl lg:text-7.5xl font-black text-white tracking-tight leading-tight max-w-4.5xl mx-auto drop-shadow-md animate-fade-in-up animation-delay-100"
        set:html={title.replace('ciudadanía activa', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-100 to-white">ciudadanía activa</span>')}
      />

      {subtitle && (
        <p class="text-lg md:text-xl text-slate-200 mt-8 max-w-3xl mx-auto leading-relaxed drop-shadow-sm animate-fade-in-up animation-delay-200">
          {subtitle}
        </p>
      )}

      {(ctaPrimary || ctaSecondary || ctaTertiary) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12 animate-fade-in-up animation-delay-300">
          {ctaPrimary && (
            <a
              href={ctaPrimary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-action text-white text-sm font-semibold rounded-lg shadow-md hover:bg-action-hover hover:scale-102 hover:shadow-lg active:bg-action-active active:scale-98 transition-all duration-300"
            >
              {ctaPrimary.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 bg-white/5 backdrop-blur-sm text-white text-sm font-semibold rounded-lg hover:bg-white/15 hover:scale-102 hover:border-white/40 active:scale-98 transition-all duration-300"
            >
              {ctaSecondary.label}
            </a>
          )}
          {ctaTertiary && (
            <a
              href={ctaTertiary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/10 bg-transparent text-white text-sm font-semibold rounded-lg hover:bg-white/5 hover:scale-102 active:scale-98 transition-all duration-300"
            >
              {ctaTertiary.label}
            </a>
          )}
        </div>
      )}

      <!-- Float in metrics container with slot -->
      <div class="animate-fade-in-up animation-delay-400">
        <slot />
      </div>
    </div>

    <!-- Sleek Bounce Scroll Indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 animate-fade-in animation-delay-500 opacity-60 pointer-events-none">
      <span class="text-[9px] font-bold tracking-widest text-slate-400 uppercase">Descubrí nuestro impacto</span>
      <div class="w-5 h-8 border border-slate-500/50 rounded-full flex justify-center p-1.5">
        <div class="w-1.5 h-1.5 bg-slate-300 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>
) : (
  <section class="relative overflow-hidden bg-institutional border-b border-slate-950 py-16 md:py-24 text-white">
    <!-- Beautiful dark abstract background image -->
    <div class="absolute inset-0 bg-cover bg-center mix-blend-overlay opacity-50 pointer-events-none" style="background-image: url('/images/hero-bg.png');" aria-hidden="true"></div>
    <!-- Dark gradient overlay for extreme readability & accessibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-institutional via-institutional/40 to-transparent opacity-90 pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white tracking-tight leading-tight max-w-4xl mx-auto drop-shadow-md">
        {title}
      </h1>

      {subtitle && (
        <p class="text-base md:text-lg text-slate-300 mt-4 max-w-2xl mx-auto leading-relaxed drop-shadow-md">
          {subtitle}
        </p>
      )}

      {(ctaPrimary || ctaSecondary) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          {ctaPrimary && (
            <a
              href={ctaPrimary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-action text-white text-sm font-semibold rounded-lg shadow-md hover:bg-action-hover hover:shadow-lg active:bg-action-active transition-all duration-200"
            >
              {ctaPrimary.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white text-sm font-semibold rounded-lg hover:bg-white/10 transition-all duration-200"
            >
              {ctaSecondary.label}
            </a>
          )}
        </div>
      )}
    </div>
  </section>
)}
