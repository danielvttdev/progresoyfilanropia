---
interface Props {
  title: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  ctaTertiary?: { label: string; href: string };
  variant?: 'home' | 'page';
  showPattern?: boolean;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  ctaPrimary,
  ctaSecondary,
  ctaTertiary,
  variant = 'page',
  showPattern = false,
  backgroundImage = '/images/hero-bg.png',
} = Astro.props;
---

{variant === 'home' ? (
  <section class="relative overflow-hidden bg-institutional text-white min-h-[85vh] lg:min-h-[90vh] flex flex-col justify-center" role="banner">
    <!-- Background -->
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0 bg-cover bg-center opacity-35 scale-105" style="background-image: url('/images/home-hero-bg.png');"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/85 via-slate-950/60 to-slate-950/30"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.012)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.012)_1px,transparent_1px)] bg-[size:72px_72px]"></div>
      <div class="absolute -top-1/3 left-[5%] w-[500px] h-[500px] rounded-full bg-white/[0.03] blur-[160px]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 w-full py-24 md:py-32 lg:pt-32 lg:pb-20">
      <div class="max-w-3xl">
        <!-- Overline -->
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full text-[10px] font-bold uppercase tracking-[0.25em] bg-white/[0.06] backdrop-blur-xl text-white/60 border border-white/[0.08] mb-8 animate-fade-in-up">
          <span class="w-1.5 h-1.5 rounded-full bg-white/80"></span>
          Tercer Sector &middot; Apartidario
        </div>

        <!-- Headline -->
        <h1
          class="text-[2.5rem] sm:text-5xl md:text-[3.5rem] lg:text-[3.75rem] xl:text-[4.25rem] font-extrabold font-display text-white tracking-tight leading-[1.1] drop-shadow-md animate-fade-in-up animation-delay-100"
          set:html={title.replace('ciudadanía activa', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-blue-400 to-indigo-300 font-serif not-italic">ciudadanía activa</span>')}
        />

        {subtitle && (
          <p class="text-base md:text-lg text-white/55 mt-6 leading-relaxed font-light max-w-xl animate-fade-in-up animation-delay-200">
            {subtitle}
          </p>
        )}

        <!-- CTAs -->
        {(ctaPrimary || ctaSecondary || ctaTertiary) && (
          <div class="flex flex-wrap gap-3 mt-10 animate-fade-in-up animation-delay-300">
            {ctaPrimary && (
              <a
                href={ctaPrimary.href}
                class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-action text-white text-sm font-bold rounded-xl shadow-lg hover:bg-action-hover hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
              >
                {ctaPrimary.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
            {ctaSecondary && (
              <a
                href={ctaSecondary.href}
                class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/20 bg-white/[0.06] backdrop-blur-sm text-white text-sm font-semibold rounded-xl hover:bg-white/[0.12] hover:border-white/30 transition-all duration-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                {ctaSecondary.label}
              </a>
            )}
            {ctaTertiary && (
              <a
                href={ctaTertiary.href}
                class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/[0.08] bg-transparent text-white/60 text-sm font-semibold rounded-xl hover:bg-white/[0.05] hover:text-white transition-all duration-300"
              >
                {ctaTertiary.label}
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 animate-fade-in animation-delay-600">
      <span class="text-[10px] font-bold tracking-[0.25em] text-white/30 uppercase">Descubrí</span>
      <div class="w-5 h-9 border-2 border-white/15 rounded-full flex justify-center pt-1.5">
        <div class="w-1 h-2 bg-white/40 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>
) : (
  <section class="relative overflow-hidden bg-institutional border-b border-slate-800 py-20 md:py-28 text-white">
    <div class="absolute inset-0 bg-cover bg-center pointer-events-none" style={`background-image: url('${backgroundImage}');`} aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950/70 via-slate-950/50 to-slate-950/20 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-[-20%] right-[-10%] w-[300px] h-[300px] rounded-full bg-white/[0.02] blur-[100px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-2xl">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-display text-white tracking-tight leading-tight drop-shadow-md">
          {title}
        </h1>

        {subtitle && (
          <p class="text-base md:text-lg text-white/50 mt-5 leading-relaxed font-light">
            {subtitle}
          </p>
        )}

        {(ctaPrimary || ctaSecondary) && (
          <div class="flex flex-wrap gap-3 mt-8">
            {ctaPrimary && (
              <a
                href={ctaPrimary.href}
                class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-action text-white text-sm font-bold rounded-xl shadow-lg hover:bg-action-hover active:bg-action-active transition-all duration-300"
              >
                {ctaPrimary.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
            {ctaSecondary && (
              <a
                href={ctaSecondary.href}
                class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/20 text-white text-sm font-semibold rounded-xl hover:bg-white/10 transition-all duration-200"
              >
                {ctaSecondary.label}
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
)}