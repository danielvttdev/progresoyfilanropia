---
import { siteConfig } from '../data/site';
import { footerNav } from '../data/navigation';
---

<footer class="bg-institutional text-slate-300" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <!-- Top: Identity -->
    <div class="mb-12">
      <a href="/" class="flex items-center gap-3 group" aria-label="Ir al inicio">
        <img
          src="/images/logo progresoyfilantropia.png"
          alt="Logo Progreso y Filantropía"
          class="h-16 w-auto object-contain brightness-0 invert transition-transform duration-300 group-hover:scale-102"
        />
        <span class="text-white font-bold tracking-tight">
          Progreso y Filantropía
        </span>
      </a>
      <p class="text-slate-400 text-sm mt-3 max-w-md">
        {siteConfig.description}
      </p>
    </div>

    <!-- Navigation Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 pb-12 border-b border-gray-800">
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-4">Institucional</h3>
        <ul class="space-y-2">
          {footerNav.institucional.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-4">Recursos</h3>
        <ul class="space-y-2">
          {footerNav.recursos.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-4">Legal</h3>
        <ul class="space-y-2">
          {footerNav.legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-4">Contacto</h3>
        <ul class="space-y-2">
          <li class="text-sm text-slate-400">{siteConfig.email}</li>
          <li class="text-sm text-slate-400">{siteConfig.phone}</li>
          <li class="text-sm text-slate-400">{siteConfig.address}</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-6 text-center sm:text-left">
        <p class="text-xs text-slate-500">
          &copy; {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
        </p>
        <p class="text-xs text-slate-500 hidden sm:block">•</p>
        <p class="text-xs text-slate-500">
          Personería Jurídica {siteConfig.personeriaJuridica}
        </p>
      </div>

      <!-- Social Media Icons Footer Block -->
      <div class="flex items-center gap-4">
        <!-- WhatsApp Chat -->
        <a 
          href="https://api.whatsapp.com/send/?phone=5491132436095&text&type=phone_number&app_absent=0&utm_source=ig" 
          target="_blank" 
          rel="noopener noreferrer" 
          aria-label="WhatsApp" 
          class="text-slate-500 hover:text-emerald-500 transition-colors duration-200"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.202-1.362a9.92 9.92 0 004.805 1.24c5.506 0 9.99-4.479 9.999-9.986.004-2.668-1.033-5.176-2.927-7.072C17.186 2.924 14.68 2.004 12.012 2zm5.72 13.916c-.244.69-1.42 1.348-1.94 1.4-.48.05-1.11.23-3.23-.65-2.73-1.13-4.47-3.9-4.61-4.08-.13-.19-1.07-1.42-1.07-2.71 0-1.29.67-1.92.91-2.18.24-.26.54-.32.72-.32.18 0 .36 0 .52.01.17 0 .4.06.6.53.22.52.73 1.79.8 1.93.07.14.11.3.01.49-.1.2-.15.31-.3.49-.15.18-.32.39-.45.52-.15.15-.31.32-.13.62.18.3.8 1.31 1.71 2.12.83.74 1.52.96 1.83 1.12.3.16.48.14.66-.06.18-.21.78-.91.99-1.22.2-.3.42-.26.71-.15.29.11 1.86.88 2.18 1.04.32.16.54.24.62.38.08.14.08.81-.16 1.5z"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a 
          href="https://www.instagram.com/progresoyfilantropia/" 
          target="_blank" 
          rel="noopener noreferrer" 
          aria-label="Instagram" 
          class="text-slate-500 hover:text-pink-500 transition-colors duration-200"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>

        <!-- WhatsApp Channel -->
        <a 
          href="https://www.whatsapp.com/channel/0029Vb68Wb96rsQvTiUJnh0Q" 
          target="_blank" 
          rel="noopener noreferrer" 
          aria-label="Canal de WhatsApp" 
          class="text-slate-500 hover:text-emerald-500 transition-colors duration-200"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12c0 2.17.7 4.19 1.89 5.83L2.5 22l4.31-1.3A9.94 9.94 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"/>
          </svg>
        </a>

        <!-- YouTube -->
        <a 
          href="https://www.youtube.com/@ar.ProgresoyFilantrop%C3%ADaSocial" 
          target="_blank" 
          rel="noopener noreferrer" 
          aria-label="YouTube" 
          class="text-slate-500 hover:text-red-500 transition-colors duration-200"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 00-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 002.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 002.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
