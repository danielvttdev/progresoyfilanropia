---
import { siteConfig } from '../data/site';
import { footerNav } from '../data/navigation';
---

<footer class="relative bg-institutional text-slate-300 overflow-hidden" role="contentinfo">
  <!-- Atmospheric glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[300px] bg-action/[0.04] blur-[160px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-indigo-500/[0.03] blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <!-- CTA strip -->
  <div class="relative border-b border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-6 py-12 md:py-16 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-center md:text-left">
        <h3 class="text-xl md:text-2xl font-bold font-display text-white tracking-tight">
          Sumate al cambio social
        </h3>
        <p class="text-sm text-slate-400 mt-2 max-w-md">
          Cada acción cuenta. Colaborá con nuestra misión de construir ciudadanía activa y bienestar general.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <a
          href="/donar/"
          class="group inline-flex items-center gap-2 px-6 py-3.5 bg-action text-white text-sm font-bold rounded-xl shadow-lg shadow-action/25 hover:bg-action-hover hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          Donar ahora
        </a>
        <a
          href="/contacto/"
          class="inline-flex items-center gap-2 px-6 py-3.5 border border-white/15 bg-white/[0.04] text-white text-sm font-semibold rounded-xl hover:bg-white/[0.08] hover:border-white/25 transition-all duration-300"
        >
          Contacto
        </a>
      </div>
    </div>
  </div>

  <!-- Main footer content -->
  <div class="relative max-w-7xl mx-auto px-6 pt-16 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-4">
        <a href="/" class="flex items-center gap-3 group" aria-label="Ir al inicio">
          <img
            src="/images/logo progresoyfilantropia.png"
            alt="Logo Progreso y Filantropía"
            class="h-12 w-auto object-contain brightness-0 invert transition-transform duration-300 group-hover:scale-105"
          />
          <div class="flex flex-col">
            <span class="text-white font-bold font-display tracking-tight leading-none">
              Progreso y Filantropía
            </span>
            <span class="text-[10px] font-medium text-slate-500 tracking-wide leading-none mt-1">
              Fundación Social
            </span>
          </div>
        </a>
        <p class="text-sm text-slate-400 mt-5 max-w-xs leading-relaxed">
          {siteConfig.description}
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-2.5 mt-6">
          <a href="https://api.whatsapp.com/send/?phone=5491132436095&text&type=phone_number&app_absent=0&utm_source=ig" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-xl bg-white/[0.06] border border-white/[0.08] flex items-center justify-center text-slate-400 hover:text-emerald-400 hover:bg-emerald-500/10 hover:border-emerald-500/20 transition-all duration-200" aria-label="WhatsApp">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 001.333 4.982L2 22l5.202-1.362a9.92 9.92 0 004.805 1.24c5.506 0 9.99-4.479 9.999-9.986.004-2.668-1.033-5.176-2.927-7.072C17.186 2.924 14.68 2.004 12.012 2zm5.72 13.916c-.244.69-1.42 1.348-1.94 1.4-.48.05-1.11.23-3.23-.65-2.73-1.13-4.47-3.9-4.61-4.08-.13-.19-1.07-1.42-1.07-2.71 0-1.29.67-1.92.91-2.18.24-.26.54-.32.72-.32.18 0 .36 0 .52.01.17 0 .4.06.6.53.22.52.73 1.79.8 1.93.07.14.11.3.01.49-.1.2-.15.31-.3.49-.15.18-.32.39-.45.52-.15.15-.31.32-.13.62.18.3.8 1.31 1.71 2.12.83.74 1.52.96 1.83 1.12.3.16.48.14.66-.06.18-.21.78-.91.99-1.22.2-.3.42-.26.71-.15.29.11 1.86.88 2.18 1.04.32.16.54.24.62.38.08.14.08.81-.16 1.5z"/></svg>
          </a>
          <a href="https://www.instagram.com/progresoyfilantropia/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-xl bg-white/[0.06] border border-white/[0.08] flex items-center justify-center text-slate-400 hover:text-pink-400 hover:bg-pink-500/10 hover:border-pink-500/20 transition-all duration-200" aria-label="Instagram">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.whatsapp.com/channel/0029Vb68Wb96rsQvTiUJnh0Q" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-xl bg-white/[0.06] border border-white/[0.08] flex items-center justify-center text-slate-400 hover:text-emerald-400 hover:bg-emerald-500/10 hover:border-emerald-500/20 transition-all duration-200" aria-label="Canal de WhatsApp">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12c0 2.17.7 4.19 1.89 5.83L2.5 22l4.31-1.3A9.94 9.94 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"/></svg>
          </a>
          <a href="https://www.youtube.com/@ar.ProgresoyFilantrop%C3%ADaSocial" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-xl bg-white/[0.06] border border-white/[0.08] flex items-center justify-center text-slate-400 hover:text-red-400 hover:bg-red-500/10 hover:border-red-500/20 transition-all duration-200" aria-label="YouTube">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 00-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 002.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 002.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <div class="lg:col-span-2">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500 mb-5">Institucional</h4>
        <ul class="space-y-3">
          {footerNav.institucional.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500 mb-5">Recursos</h4>
        <ul class="space-y-3">
          {footerNav.recursos.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500 mb-5">Legal</h4>
        <ul class="space-y-3">
          {footerNav.legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div class="lg:col-span-2">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500 mb-5">Contacto</h4>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${siteConfig.email}`} class="text-sm text-slate-400 hover:text-white transition-colors duration-200 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              <span>{siteConfig.email}</span>
            </a>
          </li>
          <li>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-sm text-slate-400 hover:text-white transition-colors duration-200 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              <span>{siteConfig.phone}</span>
            </a>
          </li>
          <li class="text-sm text-slate-500 flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            <span>{siteConfig.address}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-14 pt-8 border-t border-white/[0.06]">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-6 text-center sm:text-left">
          <p class="text-xs text-slate-500">
            &copy; {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
          </p>
          <span class="hidden sm:inline text-slate-700" aria-hidden="true">&middot;</span>
          <p class="text-xs text-slate-500">
            Personería Jurídica {siteConfig.personeriaJuridica}
          </p>
        </div>
        <p class="text-[11px] text-slate-600">
          Hecho con compromiso cívico
        </p>
      </div>
    </div>
  </div>
</footer>