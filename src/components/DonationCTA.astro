---
interface Props {
  variant?: 'inline' | 'banner';
  title?: string;
  description?: string;
}

const {
  variant = 'inline',
  title = 'Tu aporte impulsa acciones concretas',
  description = 'Cada contribución económica nos permite sostener nuestras campañas solidarias, talleres formativos, proyectos comunitarios y espacios de debate democrático.',
} = Astro.props;
---

{variant === 'banner' ? (
  <section class="relative overflow-hidden py-24 md:py-32" data-animate>
    <!-- Background layers -->
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src="/images/donation-bg.svg"
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-[#1B3A7A] via-[#1E4599] to-[#162957]"></div>
    </div>
    <!-- Atmospheric orbs -->
    <div class="absolute top-[5%] right-[-8%] w-[500px] h-[500px] rounded-full bg-white/[0.04] blur-[160px] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[350px] h-[350px] rounded-full bg-indigo-300/[0.06] blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <!-- Heart icon -->
      <div class="w-16 h-16 bg-white/[0.08] backdrop-blur-sm border border-white/[0.12] rounded-2xl flex items-center justify-center mx-auto mb-8" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold font-display text-white tracking-tight leading-tight">
        {title}
      </h2>
      <p class="text-lg text-white/70 mt-6 max-w-2xl mx-auto leading-relaxed font-light">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a
          href="/donar/"
          class="group inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-white text-[#1B3A7A] text-sm font-bold rounded-xl shadow-lg shadow-black/15 hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          Hacer una donación
        </a>
        <a
          href="/proyectos/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 bg-white/[0.08] backdrop-blur-sm text-white text-sm font-semibold rounded-xl hover:bg-white/[0.14] hover:border-white/30 transition-all duration-300"
        >
          Conocer proyectos
        </a>
      </div>

      <div class="flex items-center justify-center gap-2.5 mt-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-sm text-white/60 font-medium">Transparencia y rendición de cuentas permanente. Donaciones 100% seguras.</span>
      </div>
    </div>
  </section>
) : (
  <div class="relative bg-white/70 backdrop-blur-sm border border-slate-200/60 rounded-3xl p-10 md:p-16 shadow-sm overflow-hidden text-center max-w-4xl mx-auto">
    <div class="absolute inset-0 hero-pattern opacity-[0.04]" aria-hidden="true"></div>
    <div class="relative z-10">
      <div class="w-14 h-14 bg-action/10 text-action rounded-2xl flex items-center justify-center mx-auto mb-6" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold font-display text-slate-900 tracking-tight">
        {title}
      </h2>
      <p class="text-base text-slate-600 mt-4 max-w-2xl mx-auto leading-relaxed">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="/donar/"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-action text-white text-sm font-semibold rounded-xl shadow-lg shadow-action/15 hover:bg-action-hover hover:shadow-xl active:bg-action-active transition-all duration-300"
        >
          Hacer una donación
        </a>
        <a
          href="/proyectos/"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 border border-slate-200 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-50 hover:border-slate-300 transition-all duration-200"
        >
          Conocer proyectos
        </a>
      </div>

      <div class="flex items-center justify-center gap-2 mt-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-xs text-slate-500">Donaciones transparentes y seguras.</span>
      </div>
    </div>
  </div>
)}