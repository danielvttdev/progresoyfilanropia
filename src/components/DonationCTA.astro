---
interface Props {
  variant?: 'inline' | 'banner';
  title?: string;
  description?: string;
}

const {
  variant = 'inline',
  title = 'Tu aporte impulsa acciones concretas',
  description = 'Cada contribución económica nos permite sostener nuestras campañas solidarias, talleres formativos, proyectos comunitarios y espacios de debate democrático.',
} = Astro.props;
---

{variant === 'banner' ? (
  <section class="relative bg-gradient-to-br from-blue-50 to-slate-50 border-t border-b border-slate-100 py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 hero-pattern opacity-15" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <!-- Heart Icon -->
      <div class="w-14 h-14 bg-blue-100 text-action rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 animate-pulse-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">
        {title}
      </h2>
      <p class="text-lg text-slate-600 mt-6 max-w-2xl mx-auto leading-relaxed">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a
          href="/donar/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-action text-white text-sm font-semibold rounded-lg shadow-md shadow-blue-600/10 hover:bg-action-hover hover:shadow-lg hover:shadow-blue-600/20 active:bg-action-active transition-all duration-200"
        >
          Hacer una donación
        </a>
        <a
          href="/proyectos/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-white hover:border-slate-400 transition-all duration-200"
        >
          Conocer proyectos
        </a>
      </div>

      <!-- Trust line -->
      <div class="flex items-center justify-center gap-2 mt-8 text-xs text-slate-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span>Transparencia y rendición de cuentas permanente. Donaciones 100% seguras.</span>
      </div>
    </div>
  </section>
) : (
  <div class="relative bg-white/70 backdrop-blur-sm border border-blue-100 rounded-3xl p-10 md:p-16 shadow-sm overflow-hidden text-center max-w-4xl mx-auto">
    <div class="absolute inset-0 hero-pattern opacity-10" aria-hidden="true"></div>
    <div class="relative z-10">
      <!-- Heart Icon -->
      <div class="w-12 h-12 bg-blue-50 text-action rounded-xl flex items-center justify-center mx-auto mb-6" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 animate-pulse-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 tracking-tight">
        {title}
      </h2>
      <p class="text-base text-slate-600 mt-4 max-w-2xl mx-auto leading-relaxed">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="/donar/"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-action text-white text-sm font-semibold rounded-lg shadow-md shadow-blue-600/10 hover:bg-action-hover hover:shadow-lg active:bg-action-active transition-all duration-200"
        >
          Hacer una donación
        </a>
        <a
          href="/proyectos/"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50 hover:border-slate-400 transition-all duration-200"
        >
          Conocer proyectos
        </a>
      </div>

      <!-- Trust line -->
      <div class="flex items-center justify-center gap-2 mt-6 text-xs text-slate-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span>Donaciones transparentes y seguras.</span>
      </div>
    </div>
  </div>
)}
