---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

import Hero from '../components/Hero.astro';
import TrustBadge from '../components/TrustBadge.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ValueCard from '../components/ValueCard.astro';
import ActionCard from '../components/ActionCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogCard from '../components/BlogCard.astro';
import DonationCTA from '../components/DonationCTA.astro';
import ImpactStats from '../components/ImpactStats.astro';

const principios = [
  { label: 'Laica', icon: '⚖️' },
  { label: 'Plural', icon: '🌍' },
  { label: 'Democrática', icon: '🗳️' },
  { label: 'Republicana', icon: '🏛️' },
  { label: 'Apartidaria', icon: '🤝' },
];

const valores = [
  {
    title: 'Libertad',
    description: 'Defendemos la libertad individual y colectiva como base de toda convivencia democrática y del desarrollo humano integral.',
    image: '/images/icons/libertad.svg',
    impact: 'Impulsamos la autonomía de los ciudadanos en la gestión de sus propios proyectos y emprendimientos de impacto comunitario.',
    kpi: '100% Autogestión cívica',
  },
  {
    title: 'Igualdad',
    description: 'Trabajamos por una sociedad donde todas las personas tengan las mismas oportunidades de desarrollo y participación.',
    image: '/images/icons/igualdad.svg',
    impact: 'Aseguramos acceso libre y equitativo a todas nuestras actividades formativas, de debate cívico y de contención social barrial.',
    kpi: 'Acceso universal y plural',
  },
  {
    title: 'Fraternidad',
    description: 'Creemos en los lazos fraternos como motor de la cooperación, el cuidado mutuo y la construcción de comunidad.',
    image: '/images/icons/fraternidad.svg',
    impact: 'Fomentamos la ayuda mutua voluntaria y el asociacionismo vecinal coordinado ante problemáticas sanitarias y económicas.',
    kpi: '+1.200 Vecinos vinculados',
  },
  {
    title: 'Transparencia',
    description: 'Promovemos una gestión abierta, con rendición de cuentas permanente y comunicación clara de nuestras acciones y recursos.',
    image: '/images/icons/transparencia.svg',
    impact: 'Publicamos balances anuales, actas constitutivas y detalles contables auditados por profesionales del tercer sector.',
    kpi: 'Balances 100% públicos',
  },
  {
    title: 'Libertad de expresión',
    description: 'Valoramos el diálogo abierto y el libre intercambio de ideas como pilares de una democracia sana y participativa.',
    image: '/images/icons/expresion.svg',
    impact: 'Impulsamos debates plurales, foros vecinales abiertos y transmisiones en streaming que integran todas las opiniones ciudadanas.',
    kpi: 'Diálogo democrático',
  },
  {
    title: 'Respeto por todas las opiniones',
    description: 'Creamos espacios donde cada voz es escuchada con atención, promoviendo la pluralidad como riqueza colectiva.',
    image: '/images/icons/respeto.svg',
    impact: 'Articulamos mesas de concertación pluralista y democrática para consensuar soluciones territoriales de forma participativa.',
    kpi: 'Pluralismo activo',
  },
];

const areasDeImpacto = [
  { label: 'Sanitaria', icon: '🏥' },
  { label: 'Económica', icon: '📊' },
  { label: 'Cultural', icon: '🎭' },
  { label: 'Ambiental', icon: '🌱' },
  { label: 'Científica', icon: '🔬' },
  { label: 'Educativa', icon: '📚' },
];

const proyectosDestacados = [
  {
    title: 'Programa de acompañamiento comunitario',
    description: 'Equipos de trabajo territorial que asisten y acompañan a familias en situación de vulnerabilidad, fortaleciendo redes de contención y cuidado mutuo.',
    category: 'Sanitaria',
    status: 'Activo',
    image: '/images/projects/acompanamiento.png',
  },
  {
    title: 'Talleres de formación ciudadana',
    description: 'Ciclos de formación en participación cívica, pensamiento crítico y herramientas para la construcción colectiva de soluciones comunitarias.',
    category: 'Educativa',
    status: 'Activo',
    image: '/images/projects/talleres.png',
  },
  {
    title: 'Programa de streaming Comunidad Global',
    description: 'Entrevistas y debates sobre las experiencias de vida, resiliencia, aportes culturales y emprendimientos de migrantes de diversas partes del mundo.',
    category: 'Cultural',
    status: 'Activo',
    image: '/images/projects/streaming.png',
  },
];

const redDeCooperacion = [
  { label: 'Universidades', icon: '🎓', desc: 'Convenios académicos, pasantías e investigación aplicada para el desarrollo territorial.' },
  { label: 'Asociaciones civiles', icon: '🏢', desc: 'Alianzas con organizaciones del tercer sector para ampliar el impacto social en el territorio.' },
  { label: 'Fundaciones', icon: '🤝', desc: 'Cooperación interinstitucional con fundaciones nacionales e internacionales.' },
  { label: 'Entidades sin fines de lucro', icon: '💡', desc: 'Articulación de recursos y saberes con organizaciones de la sociedad civil.' },
  { label: 'Organizaciones comunitarias', icon: '🏘️', desc: 'Trabajo directo con agrupaciones barriales y vecinales para soluciones locales.' },
];

const metricas = [
  { value: '+1.200', label: 'Personas alcanzadas' },
  { value: '48', label: 'Actividades realizadas' },
  { value: '+30', label: 'Organizaciones aliadas' },
  { value: '12', label: 'Proyectos activos' },
];

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  noticias: 'Noticias',
  eventos: 'Eventos',
  'historias-de-impacto': 'Historias de Impacto',
  analisis: 'Análisis',
  transparencia: 'Transparencia',
  anuncios: 'Anuncios',
};
---

<BaseLayout
  title="Inicio"
  description="Fundación Progreso y Filantropía Social: organización ciudadana del tercer sector que construye ciudadanía activa, participativa y comprometida con el bienestar general."
  transparentHeader={true}
>

  <!-- ========== 1. HERO ========== -->
  <Hero
    variant="home"
    showPattern={true}
    title="Impulsamos la ciudadanía activa para fortalecer la convivencia y la cohesión social"
    subtitle="Desde el tercer sector fomentamos la participación ciudadana, la transparencia cívica y la cooperación territorial, construyendo puentes para el bienestar general y el progreso de cada persona."
    ctaPrimary={{ label: 'Conocé nuestros proyectos', href: '/proyectos/' }}
    ctaSecondary={{ label: 'Donar', href: '/donar/' }}
    ctaTertiary={{ label: 'Involúcrate', href: '/contacto/' }}
  />

  <!-- ========== HERO STATS ========== -->
  <section class="relative bg-institutional border-t border-white/[0.06] py-10 md:py-14" data-animate>
    <div class="relative max-w-7xl mx-auto px-6">
      <ImpactStats stats={metricas} variant="dark" />
    </div>
  </section>

  <!-- ========== 2. PRINCIPIOS — Marquee ========== -->
  <section class="bg-white py-8 border-b border-slate-100/80 overflow-hidden" aria-label="Principios institucionales">
    <TrustBadge items={principios} />
  </section>

  <!-- ========== 3. QUIÉNES SOMOS — Editorial Asymmetric ========== -->
  <section class="relative bg-white py-24 md:py-32 overflow-hidden" data-animate>
    <div class="absolute inset-0 gradient-mesh-subtle pointer-events-none" aria-hidden="true"></div>
    <!-- Decorative accent line -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-action/10 to-transparent" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Text column -->
        <div class="lg:col-span-7">
          <div class="flex items-center gap-2.5 mb-8">
            <div class="w-8 h-1 bg-slate-900 rounded-full"></div>
            <div class="w-2 h-1 bg-slate-300 rounded-full"></div>
            <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-slate-400">Sobre nosotros</span>
          </div>
          <SectionTitle
            title="Una fundación ciudadana al servicio del bien común"
            accentLine={false}
            align="left"
          />

          <!-- Pull quote -->
          <blockquote class="relative my-8 pl-6 border-l-[3px] border-slate-900">
            <p class="text-lg md:text-xl font-serif italic text-slate-700 leading-relaxed">
              Construimos ciudadanía activa, participativa, empática y con fuerte compromiso comunitario.
            </p>
          </blockquote>

          <div class="text-slate-600 leading-relaxed space-y-4">
            <p>
              Progreso y Filantropía Social es una organización del tercer sector que trabaja para fortalecer la convivencia pacífica, los lazos fraternos, el bienestar general y el desarrollo integral de cada individuo.
            </p>
            <p>
              Somos una institución laica, plural, democrática, republicana y apartidaria. Promovemos la cooperación entre personas, organizaciones e instituciones para amplificar el impacto de cada acción solidaria.
            </p>
          </div>

          <div class="mt-10 pt-8 border-t border-slate-100">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.25em] text-slate-400 mb-5">Nuestras áreas de incidencia cívica</h4>
            <div class="flex flex-wrap gap-2.5">
              {areasDeImpacto.map((area) => (
                <div class="group inline-flex items-center gap-2 px-4 py-2.5 bg-slate-50 border border-slate-200/70 rounded-full text-xs font-semibold text-slate-600 hover:bg-action-light hover:text-action hover:border-action/20 hover:shadow-sm transition-all duration-300 cursor-default">
                  <span class="text-sm group-hover:scale-110 transition-transform duration-300" aria-hidden="true">{area.icon}</span>
                  <span>{area.label}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-8">
            <a
              href="/quienes-somos/"
              class="group inline-flex items-center gap-2.5 px-6 py-3 bg-slate-900 text-white text-sm font-semibold rounded-xl hover:bg-slate-800 hover:shadow-lg hover:shadow-slate-900/15 active:bg-slate-950 transition-all duration-300"
            >
              Conocé más sobre nosotros
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Image column — editorial treatment -->
        <div class="lg:col-span-5">
          <div class="relative group">
            <!-- Decorative offset frame -->
            <div class="absolute -bottom-4 -right-4 w-full h-full rounded-3xl border-2 border-action/10 pointer-events-none" aria-hidden="true"></div>
            <!-- Glow -->
            <div class="absolute -inset-4 bg-gradient-to-tr from-slate-900/[0.04] to-slate-500/[0.03] rounded-[2.5rem] blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" aria-hidden="true"></div>
            <div class="relative rounded-3xl overflow-hidden shadow-xl shadow-slate-200/50">
              <div class="aspect-[4/5] w-full bg-slate-100 relative">
                <img
                  src="/images/home-about.png"
                  alt="Imagen de cooperación y unión vecinal, Fundación Progreso y Filantropía Social"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                  loading="lazy"
                />
                <!-- Bottom gradient -->
                <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-slate-900/30 to-transparent pointer-events-none" aria-hidden="true"></div>
              </div>
            </div>
            <!-- Floating detail -->
            <div class="absolute -bottom-3 -left-3 bg-white shadow-lg shadow-slate-200/60 rounded-2xl px-5 py-3.5 border border-slate-100" aria-hidden="true">
              <p class="text-2xl font-extrabold font-display text-slate-900 leading-none">+1.200</p>
              <p class="text-[11px] font-medium text-slate-500 mt-0.5">Personas alcanzadas</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 4. VALORES INSTITUCIONALES ========== -->
  <section class="relative bg-slate-50/40 py-24 md:py-32 overflow-hidden" id="valores-section" data-animate>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-4">
        <span class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.25em] text-slate-500">
          <span class="w-6 h-px bg-slate-300" aria-hidden="true"></span>
          Nuestro fundamento ético
          <span class="w-6 h-px bg-slate-300" aria-hidden="true"></span>
        </span>
      </div>
      <SectionTitle
        title="Valores que orientan nuestra acción"
        subtitle="Los pilares sobre los que construimos una ciudadanía activa, solidaria y comprometida con el bienestar general."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6 mt-14">
        {valores.map((valor, idx) => (
          <article
            class="group relative bg-white border border-slate-200/60 rounded-2xl overflow-hidden card-hover flex flex-col"
            style={`animation: val-reveal 0.5s cubic-bezier(0.16,1,0.3,1) both; animation-delay: ${idx * 80}ms;`}
          >
            <div class="p-7 flex flex-col flex-grow">
              <!-- Icon + title -->
              <div class="flex items-start gap-4 mb-4">
                <div class="shrink-0 w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center group-hover:bg-slate-900 group-hover:shadow-lg transition-all duration-500">
                  <img
                    src={valor.image}
                    alt={valor.title}
                    class="w-6 h-6 object-contain brightness-0 group-hover:brightness-0 group-hover:invert transition-all duration-500"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="text-lg font-bold font-display text-slate-900 leading-tight group-hover:text-slate-900 transition-colors duration-300">
                    {valor.title}
                  </h3>
                  <span class="inline-flex items-center mt-1 px-2 py-0.5 rounded-md text-[10px] font-bold uppercase tracking-[0.12em] text-slate-500 bg-slate-100">
                    {valor.kpi}
                  </span>
                </div>
              </div>

              <!-- Description -->
              <p class="text-sm text-slate-500 leading-relaxed flex-grow">
                {valor.description}
              </p>

              <!-- Bottom link -->
              <div class="pt-5 mt-auto border-t border-slate-100">
                <button
                  type="button"
                  class="val-toggle w-full flex items-center justify-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-slate-900 transition-colors duration-200"
                  aria-label={`Ver más sobre ${valor.title}`}
                  data-idx={idx}
                >
                  <span class="val-toggle-text">Ver impacto</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 val-chevron transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              </div>

              <!-- Expandable impact -->
              <div class="val-impact overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" style="max-height: 0; opacity: 0;">
                <div class="pt-4 mt-4 border-t border-slate-100">
                  <p class="text-sm text-slate-600 leading-relaxed">
                    <strong class="text-slate-900">En acción:</strong> {valor.impact}
                  </p>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    @keyframes val-reveal {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.val-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
          const card = btn.closest('article');
          const impact = card.querySelector('.val-impact');
          const chevron = btn.querySelector('.val-chevron');
          const textEl = btn.querySelector('.val-toggle-text');
          const isOpen = impact.style.maxHeight !== '0px' && impact.style.maxHeight !== '';

          // close all first
          document.querySelectorAll('.val-impact').forEach(el => { el.style.maxHeight = '0px'; el.style.opacity = '0'; });
          document.querySelectorAll('.val-chevron').forEach(el => el.style.transform = '');
          document.querySelectorAll('.val-toggle-text').forEach(el => el.textContent = 'Ver impacto');

          if (!isOpen) {
            impact.style.maxHeight = '200px';
            impact.style.opacity = '1';
            chevron.style.transform = 'rotate(180deg)';
            textEl.textContent = 'Cerrar';
          }
        });
      });
    });
  </script>

  <!-- ========== 7. PROYECTOS DESTACADOS ========== -->
  <section class="relative bg-slate-50/40 py-24 md:py-32 overflow-hidden" data-animate>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="text-center mb-4">
        <span class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.25em] text-action/70">
          <span class="w-6 h-px bg-action/30" aria-hidden="true"></span>
          Impacto en acción
          <span class="w-6 h-px bg-action/30" aria-hidden="true"></span>
        </span>
      </div>
      <SectionTitle
        title="Proyectos destacados"
        subtitle="Iniciativas que transforman realidades y fortalecen el tejido comunitario."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {proyectosDestacados.map((proyecto) => (
          <ProjectCard
            title={proyecto.title}
            description={proyecto.description}
            category={proyecto.category}
            status={proyecto.status}
            href="/proyectos/"
            image={proyecto.image}
          />
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/proyectos/"
          class="group inline-flex items-center gap-2.5 px-7 py-3.5 bg-slate-900 text-white text-sm font-semibold rounded-xl hover:bg-slate-800 hover:shadow-lg hover:shadow-slate-900/20 active:bg-slate-950 transition-all duration-300"
        >
          Ver todos los proyectos
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

<!-- ========== 8. RED DE COOPERACIÓN — Interactive Premium ========== -->
  <section class="relative bg-white py-24 md:py-32 overflow-hidden" id="red-section" data-animate>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-slate-200/60 to-transparent"></div>
      <div class="absolute top-[20%] left-[-10%] w-[500px] h-[500px] rounded-full bg-slate-900/[0.02] blur-[160px]"></div>
      <div class="absolute bottom-[10%] right-[-8%] w-[400px] h-[400px] rounded-full bg-slate-500/[0.02] blur-[120px]"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
        <!-- Left: copy + CTA -->
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <div class="flex items-center gap-2.5 mb-6">
            <div class="w-8 h-1 bg-slate-900 rounded-full"></div>
            <div class="w-2 h-1 bg-slate-300 rounded-full"></div>
            <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-slate-400">Cooperación</span>
          </div>
          <SectionTitle
            title="Trabajo articulado en red"
            accentLine={false}
            align="left"
          />
          <div class="text-slate-600 leading-relaxed text-base space-y-4 mt-6">
            <p>
              Entendemos la cooperación horizontal como el único camino viable para construir respuestas de impacto social sustentable en el territorio.
            </p>
            <p>
              Articulamos esfuerzos con universidades, asociaciones civiles y agrupaciones comunitarias barriales para multiplicar el alcance de cada iniciativa.
            </p>
          </div>

          <!-- Animated network visualization -->
          <div class="relative mt-8 mb-2 flex items-center justify-center" aria-hidden="true">
            <div class="red-network-node absolute w-3 h-3 bg-white rounded-full shadow-lg shadow-white/30 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10 animate-pulse"></div>
            <svg id="red-network-svg" class="absolute inset-0 w-full h-full" viewBox="0 0 200 120"></svg>
            <div class="w-32 h-20"></div>
          </div>

          <div class="mt-4">
            <a
              href="/red-de-cooperacion/"
              class="group inline-flex items-center gap-2.5 px-6 py-3 bg-slate-900 text-white text-sm font-semibold rounded-xl hover:bg-slate-800 hover:shadow-lg hover:shadow-slate-900/15 active:bg-slate-950 transition-all duration-300"
            >
              Conocé nuestra red de cooperación
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: interactive bento cards -->
        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 lg:gap-5" id="red-cards-grid">
            {redDeCooperacion.map((org, i) => (
              <div
                class={`network-card group relative flex flex-col items-center gap-3 p-6 sm:p-7 bg-white border border-slate-200/60 rounded-2xl overflow-hidden transition-all duration-500 cursor-default`}
                data-card-idx={i}
                data-accent={org.accent || '#3B5FD4'}
                style={`--delay: ${i * 80}ms`}
              >
                <!-- Hover gradient border -->
                <div class="absolute inset-0 rounded-2xl p-[1px] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500" style={`background: linear-gradient(135deg, #3B5FD4, color-mix(in srgb, #3B5FD4 30%, transparent)); -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; padding: 1px; border-radius: 1rem;`}></div>

                <!-- Static border -->
                <div class="absolute inset-0 rounded-2xl border border-slate-200/60 transition-all duration-500 group-hover:border-transparent pointer-events-none"></div>

                <!-- Hover bg -->
                <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: linear-gradient(135deg, rgba(59, 95, 212, 0.06) 0%, white 70%);"></div>

                <!-- Active expanded backdrop -->
                <div class="network-card-backdrop absolute inset-0 rounded-2xl pointer-events-none transition-opacity duration-300 opacity-0" style="background: linear-gradient(135deg, rgba(59, 95, 212, 0.1) 0%, white 40%);"></div>

                <!-- Mouse-follow glow -->
