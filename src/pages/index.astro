  <style>
    .network-card {
      animation: card-reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: var(--delay);
      will-change: transform;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes card-reveal {
      from {
        opacity: 0;
        transform: translateY(20px) scale(0.97);
        filter: blur(4px);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
    }

    .network-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 48px -12px rgba(59, 95, 212, 0.1);
    }

    .network-card.is-expanded .network-card-desc {
      max-height: 120px !important;
      opacity: 1 !important;
    }

    .network-card.is-expanded .network-card-chevron {
      transform: rotate(180deg);
    }

    .network-card.is-expanded .network-card-toggle-text {
      display: none;
    }

    .network-card.is-expanded .network-card-backdrop {
      opacity: 1;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.network-card');

      // --- Click to expand/collapse ---
      cards.forEach((card) => {
        const toggle = card.querySelector('.network-card-toggle');
        if (!toggle) return;

        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const wasExpanded = card.classList.contains('is-expanded');
          cards.forEach((c) => c.classList.remove('is-expanded'));
          if (!wasExpanded) {
            card.classList.add('is-expanded');
          }
        });
      });

      // --- Mouse-follow glow ---
      cards.forEach((card) => {
        const glow = card.querySelector('.network-card-glow');
        if (!glow) return;

        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          glow.style.left = x + 'px';
          glow.style.top = y + 'px';
          glow.style.opacity = '1';
        });

        card.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        });
      });

      // --- Staggered scroll reveal ---
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.style.animationPlayState = 'running';
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });
        cards.forEach((card) => {
          card.style.animationPlayState = 'paused';
          observer.observe(card);
        });
      }

      // --- Animated network SVG ---
      const svg = document.getElementById('red-network-svg');
      if (svg) {
        const cx = 100, cy = 60;
        const nodes = [
          { angle: -90, dist: 40, label: '' },
          { angle: -30, dist: 40, label: '' },
          { angle: 30, dist: 40, label: '' },
          { angle: 90, dist: 40, label: '' },
          { angle: 150, dist: 40, label: '' },
          { angle: 210, dist: 40, label: '' },
        ];

        let linesHTML = '';
        let dotsHTML = '';

        nodes.forEach((node, i) => {
          const rad = (node.angle * Math.PI) / 180;
          const x = cx + Math.cos(rad) * node.dist;
          const y = cy + Math.sin(rad) * node.dist;

          linesHTML += `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="rgba(15,23,42,0.15)" stroke-width="1" stroke-dasharray="3,3"><animate attributeName="stroke-opacity" values="0.1;0.3;0.1" dur="${2 + i * 0.3}s" repeatCount="indefinite" /></line>`;
          dotsHTML += `<circle cx="${x}" cy="${y}" r="3" fill="currentColor" class="text-slate-400" opacity="0.3"><animate attributeName="r" values="2;4;2" dur="${2 + i * 0.2}s" repeatCount="indefinite" /><animate attributeName="opacity" values="0.2;0.5;0.2" dur="${2 + i * 0.2}s" repeatCount="indefinite" /></circle>`;
        });

        // Center node
        dotsHTML += `<circle cx="${cx}" cy="${cy}" r="5" fill="currentColor" class="text-slate-600" opacity="0.5"><animate attributeName="r" values="4;6;4" dur="2s" repeatCount="indefinite" /></circle>`;

        // Outer connection lines between nodes
        for (let i = 0; i < nodes.length; i++) {
          const next = (i + 1) % nodes.length;
          const rad1 = (nodes[i].angle * Math.PI) / 180;
          const rad2 = (nodes[next].angle * Math.PI) / 180;
          const x1 = cx + Math.cos(rad1) * nodes[i].dist;
          const y1 = cy + Math.sin(rad1) * nodes[i].dist;
          const x2 = cx + Math.cos(rad2) * nodes[next].dist;
          const y2 = cy + Math.sin(rad2) * nodes[next].dist;
          linesHTML += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="rgba(15,23,42,0.06)" stroke-width="1" />`;
        }

        svg.innerHTML = linesHTML + dotsHTML;
      }
    });
  </script>

