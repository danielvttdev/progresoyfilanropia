---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featuredPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);

const categoryLabels: Record<string, string> = {
  noticias: 'Noticias',
  eventos: 'Eventos',
  'historias-de-impacto': 'Historias de Impacto',
  analisis: 'Análisis',
  transparencia: 'Transparencia',
  anuncios: 'Anuncios',
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-AR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Novedades"
  description="Noticias, ideas, análisis y reflexiones de la Fundación Progreso y Filantropía Social sobre ciudadanía, solidaridad y participación comunitaria."
>
  <!-- Hero -->
  <Hero
    variant="page"
    backgroundImage="/images/novedades-hero-bg.svg"
    title="Noticias, ideas y reflexiones para una sociedad mejor"
    subtitle="Seguí el día a día de nuestras actividades territoriales, análisis institucionales y debates democráticos."
  />

  <section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      {sortedPosts.length > 0 ? (
        <div class="space-y-16">
          <!-- Featured Post -->
          {featuredPost && (
            <article class="group bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 grid grid-cols-1 md:grid-cols-12 max-w-6xl mx-auto">
              <!-- Image placeholder left -->
              <div class="aspect-video md:aspect-auto md:col-span-6 bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center relative overflow-hidden min-h-[300px]">
                {featuredPost.data.image ? (
                  <img
                    src={featuredPost.data.image}
                    alt={featuredPost.data.title}
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-slate-300 group-hover:scale-105 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2-2m2 2a2 2 0 11-4 0m4 0v6a2 2 0 01-2 2H9" />
                  </svg>
                )}
                <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <span class="absolute top-4 left-4 z-10 inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-action text-white uppercase tracking-wider">
                  Destacado
                </span>
              </div>
              <!-- Content right -->
              <div class="p-8 md:p-12 md:col-span-6 flex flex-col justify-between">
                <div>
                  <div class="flex items-center gap-3 mb-4 text-xs font-medium text-slate-500">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full font-semibold bg-action-light text-action uppercase tracking-wider text-[10px]">
                      {categoryLabels[featuredPost.data.category] || featuredPost.data.category}
                    </span>
                    <time datetime={featuredPost.data.pubDate.toISOString()}>
                      {formatDate(featuredPost.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 group-hover:text-action transition-colors duration-200 leading-tight mb-4">
                    <a href={`/blog/${featuredPost.id}/`}>
                      {featuredPost.data.title}
                    </a>
                  </h2>
                  <p class="text-slate-600 leading-relaxed mb-6">
                    {featuredPost.data.description}
                  </p>
                </div>
                <div class="flex items-center justify-between pt-6 border-t border-slate-100 mt-auto">
                  {featuredPost.data.author && (
                    <span class="text-xs text-slate-500 font-semibold">
                      Por {featuredPost.data.author}
                    </span>
                  )}
                  <a
                    href={`/blog/${featuredPost.id}/`}
                    class="inline-flex items-center gap-1 text-sm font-bold text-action hover:text-action-hover transition-colors"
                  >
                    Leer artículo
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          )}

          <!-- Remaining Posts Grid -->
          {remainingPosts.length > 0 && (
            <div class="space-y-10 border-t border-slate-100 pt-16">
              <SectionTitle
                title="Más publicaciones"
                align="left"
              />
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {remainingPosts.map((post) => (
                  <BlogCard
                    title={post.data.title}
                    description={post.data.description}
                    category={categoryLabels[post.data.category] || post.data.category}
                    date={post.data.pubDate}
                    slug={post.id}
                    author={post.data.author}
                    image={post.data.image}
                  />
                ))}
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="text-center py-16 bg-slate-50 rounded-3xl border border-slate-100 max-w-xl mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-slate-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1" />
          </svg>
          <h3 class="text-lg font-bold text-slate-900">No hay publicaciones</h3>
          <p class="text-sm text-slate-500 mt-2">Próximamente compartiremos las novedades de la fundación.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
