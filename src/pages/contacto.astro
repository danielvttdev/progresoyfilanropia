---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout
  title="Contacto"
  description="Contactate con la Fundación Progreso y Filantropía Social. Escribinos para sumarte como voluntario, donante o proponer alianzas."
>
  <!-- Hero -->
  <Hero
    variant="page"
    title="Contactá con Progreso y Filantropía Social"
    subtitle="Escribinos tus consultas, propuestas de alianzas, iniciativas o intenciones de donación."
  />

  <section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start max-w-6xl mx-auto">
        
        <!-- LEFT: Contact Form (7 cols) -->
        <div class="lg:col-span-7 bg-white rounded-3xl p-8 border border-slate-200 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 mb-6">Envianos un mensaje</h2>
          
          <form action="#" method="POST" class="space-y-5">
            <div>
              <label for="nombre" class="text-sm font-semibold text-slate-700 mb-1.5 block">
                Nombre completo
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Juan Pérez"
                class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-700 bg-white focus:border-action focus:ring-1 focus:ring-action outline-none transition-colors"
              />
            </div>

            <div>
              <label for="email" class="text-sm font-semibold text-slate-700 mb-1.5 block">
                Correo electrónico
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="juan@example.com"
                class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-700 bg-white focus:border-action focus:ring-1 focus:ring-action outline-none transition-colors"
              />
            </div>

            <div>
              <label for="motivo" class="text-sm font-semibold text-slate-700 mb-1.5 block">
                Motivo de consulta
              </label>
              <select
                id="motivo"
                name="motivo"
                required
                class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-700 bg-white focus:border-action focus:ring-1 focus:ring-action outline-none transition-colors"
              >
                <option value="">Selecciona una opción</option>
                <option value="participar">Quiero participar como voluntario</option>
                <option value="donar">Quiero realizar una donación</option>
                <option value="alianza">Quiero proponer una alianza institucional</option>
                <option value="prensa">Prensa y comunicación</option>
                <option value="otro">Otro motivo</option>
              </select>
            </div>

            <div>
              <label for="mensaje" class="text-sm font-semibold text-slate-700 mb-1.5 block">
                Mensaje
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                required
                placeholder="Escribe tu mensaje aquí..."
                class="w-full px-4 py-3 border border-slate-200 rounded-lg text-sm text-slate-700 bg-white focus:border-action focus:ring-1 focus:ring-action outline-none transition-colors resize-none"
              ></textarea>
            </div>

            <div class="pt-2">
              <button
                type="submit"
                class="w-full inline-flex items-center justify-center px-6 py-4 bg-action text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-action-hover active:bg-action-active transition-all duration-200 cursor-pointer"
              >
                Enviar mensaje
              </button>
            </div>
          </form>
        </div>

        <!-- RIGHT: Info Columns (5 cols) -->
        <div class="lg:col-span-5 space-y-6">
          
          <!-- General Contact Info -->
          <div class="bg-slate-50 border border-slate-100 rounded-3xl p-8 space-y-6">
            <h2 class="text-lg font-bold text-slate-900">Información institucional</h2>
            
            <div class="space-y-4">
              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center border border-slate-150 text-slate-500" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <span class="text-xs font-semibold text-slate-500 block">Correo electrónico</span>
                  <a href={`mailto:${siteConfig.email}`} class="text-sm font-bold text-slate-800 hover:text-action transition-colors">
                    {siteConfig.email}
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center border border-slate-150 text-slate-500" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <span class="text-xs font-semibold text-slate-500 block">Teléfono de atención</span>
                  <span class="text-sm font-bold text-slate-800">
                    {siteConfig.phone}
                  </span>
                </div>
              </div>

              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center border border-slate-150 text-slate-500" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <span class="text-xs font-semibold text-slate-500 block">Ubicación</span>
                  <span class="text-sm font-bold text-slate-800">
                    {siteConfig.address}
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- Shortcuts -->
          <div class="border border-slate-200 rounded-3xl p-8 space-y-4">
            <h3 class="text-base font-bold text-slate-900 mb-2">Canales rápidos</h3>
            
            <a
              href="/donar/"
              class="flex items-center justify-between p-4 bg-slate-50 border border-slate-100 rounded-2xl hover:bg-slate-100/50 hover:border-slate-200 transition-all duration-200 group"
            >
              <div>
                <span class="text-sm font-bold text-slate-800 block">¿Querés donar directamente?</span>
                <span class="text-xs text-slate-500 block">Descubrí las formas seguras de colaborar.</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 group-hover:text-action group-hover:translate-x-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

            <a
              href="/proyectos/"
              class="flex items-center justify-between p-4 bg-slate-50 border border-slate-100 rounded-2xl hover:bg-slate-100/50 hover:border-slate-200 transition-all duration-200 group"
            >
              <div>
                <span class="text-sm font-bold text-slate-800 block">Conocé nuestros proyectos</span>
                <span class="text-xs text-slate-500 block">Mirá en qué estamos trabajando hoy.</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400 group-hover:text-action group-hover:translate-x-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Redes Sociales -->
  <section class="bg-slate-50 py-16 border-t border-slate-150 text-center" data-animate>
    <div class="max-w-4xl mx-auto px-6">
      <SectionTitle
        title="Nuestras redes sociales"
        subtitle="Seguinos para enterarte al instante de nuestras novedades y convocatorias cívicas."
        align="center"
      />
      
      <div class="flex justify-center gap-4 mt-6">
        <a
          href="#"
          aria-label="Facebook"
          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-600 hover:text-action hover:border-action-light hover:bg-action-light hover:-translate-y-1 transition-all duration-300 shadow-sm"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M9 8H7v3h2v9h3v-9h2.72l.42-3H12V6c0-.88.11-1 .9-.1H15V2h-2.5C10 2 9 3 9 5.5V8z"/>
          </svg>
        </a>

        <a
          href="#"
          aria-label="Instagram"
          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-600 hover:text-action hover:border-action-light hover:bg-action-light hover:-translate-y-1 transition-all duration-300 shadow-sm"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>

        <a
          href="#"
          aria-label="X (ex Twitter)"
          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-600 hover:text-action hover:border-action-light hover:bg-action-light hover:-translate-y-1 transition-all duration-300 shadow-sm"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>

        <a
          href="#"
          aria-label="LinkedIn"
          class="w-12 h-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-600 hover:text-action hover:border-action-light hover:bg-action-light hover:-translate-y-1 transition-all duration-300 shadow-sm"
        >
          <svg class="w-5 h-5 fill-currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
