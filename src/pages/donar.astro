---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ActionCard from '../components/ActionCard.astro';

const destinacion = [
  {
    title: 'Campañas humanitarias',
    description: 'Asistencia alimentaria, kits sanitarios y acompañamiento directo a familias vulnerables en emergencias sociales.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
  },
  {
    title: 'Talleres educativos',
    description: 'Espacios formativos presenciales y virtuales sobre ciudadanía, derechos, tecnología y desarrollo individual.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
  },
  {
    title: 'Participación ciudadana',
    description: 'Foros de debate, encuentros de deliberación abierta y mesas redondas vecinales para la convivencia pacífica.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
  {
    title: 'Proyectos comunitarios',
    description: 'Equipos territoriales que diseñan soluciones a demandas específicas de infraestructura local y saneamiento.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
  },
  {
    title: 'Emprendimientos sociales',
    description: 'Microcréditos, mentorías y herramientas técnicas para incentivar la autonomía económica de sectores relegados.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  },
  {
    title: 'Cooperación institucional',
    description: 'Articulación de programas de alcance nacional junto a universidades y otras organizaciones del tercer sector.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>`,
  },
];

const metodos = [
  {
    title: 'Mercado Pago',
    status: 'Próximamente disponible',
    description: 'Donaciones rápidas con tarjeta de débito, crédito o dinero en cuenta.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
    btnText: 'Mercado Pago',
    disabled: true,
  },
  {
    title: 'Transferencia bancaria',
    status: 'Activo (Solicitar datos)',
    description: 'Aportes únicos o recurrentes directamente a nuestra cuenta institucional.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>`,
    btnText: 'Solicitar CBU',
    disabled: false,
    href: '/contacto/?motivo=donar',
  },
  {
    title: 'Donación mensual',
    status: 'Próximamente disponible',
    description: 'Adherí un aporte automático mensual para brindar sustentabilidad a largo plazo.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    btnText: 'Suscripción mensual',
    disabled: true,
  },
  {
    title: 'Donación institucional',
    status: 'Activo',
    description: 'Convenios de responsabilidad social, donaciones de empresas o cooperaciones especiales.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    btnText: 'Coordinar alianza',
    disabled: false,
    href: '/contacto/?motivo=donar',
  },
];
---

<BaseLayout
  title="Donar"
  description="Doná para la Fundación Progreso y Filantropía Social. Tu aporte impulsa nuestras campañas solidarias, talleres y proyectos comunitarios."
  transparentHeader={true}
>
  <!-- 1. Hero -->
  <Hero
    variant="page"
    title="Doná para impulsar acciones solidarias, educativas y comunitarias"
    subtitle="Cada aporte económico nos ayuda a sostener iniciativas ciudadanas orientadas al bien común, el fortalecimiento de la convivencia y el desarrollo social."
  />

  <!-- 2. Por qué donar -->
  <section class="bg-white py-20 md:py-28" data-animate>
    <div class="max-w-4xl mx-auto px-6">
      <SectionTitle
        title="Tu aporte genera impacto social directo"
        accentLine={true}
        align="center"
      />
      <div class="prose max-w-none text-slate-600 text-center leading-relaxed space-y-6">
        <p class="text-lg">
          En <strong>Progreso y Filantropía Social</strong>, consideramos que la solidaridad no es un acto asistencial aislado, sino una herramienta de transformación comunitaria. Tu donación nos permite planificar proyectos sostenibles en el tiempo, garantizando autonomía, transparencia e incidencia positiva real.
        </p>
        <p class="text-base">
          Como organización laica, plural y apartidaria, financiamos nuestras actividades a través del aporte de ciudadanos comprometidos y alianzas institucionales, asegurando absoluta independencia en cada una de nuestras líneas de acción.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. A qué se destinan -->
  <section class="bg-slate-50 py-20 md:py-28" data-animate>
    <div class="max-w-7xl mx-auto px-6">
      <SectionTitle
        title="A qué se destinan los recursos"
        subtitle="Todo aporte se asocia a metas claras y programas de incidencia directa en el territorio."
        align="center"
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {destinacion.map((item) => (
          <ActionCard
            title={item.title}
            description={item.description}
            icon={item.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Métodos de donación -->
  <section class="bg-white py-20 md:py-28" data-animate>
    <div class="max-w-7xl mx-auto px-6">
      <SectionTitle
        title="Canales de colaboración"
        subtitle="Elegí la modalidad de donación que te resulte más cómoda."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {metodos.map((metodo) => (
          <div class="bg-white border border-slate-200 rounded-3xl p-8 flex flex-col justify-between shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
            <div>
              <div class="flex items-center justify-between gap-4 mb-6">
                <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center border border-slate-100" aria-hidden="true">
                  <Fragment set:html={metodo.icon} />
                </div>
                <span class={`px-3 py-1 rounded-full text-xs font-semibold ${metodo.disabled ? 'bg-slate-100 text-slate-500' : 'bg-emerald-50 text-emerald-700'}`}>
                  {metodo.status}
                </span>
              </div>
              <h3 class="text-lg font-bold text-slate-900 mb-2">{metodo.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-8">{metodo.description}</p>
            </div>
            <div>
              {metodo.disabled ? (
                <button
                  disabled
                  class="w-full inline-flex items-center justify-center px-6 py-3 bg-slate-100 text-slate-400 text-sm font-semibold rounded-lg cursor-not-allowed border border-slate-150"
                >
                  {metodo.btnText}
                </button>
              ) : (
                <a
                  href={metodo.href}
                  class="w-full inline-flex items-center justify-center px-6 py-3 bg-action text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-action-hover transition-colors duration-200"
                >
                  {metodo.btnText}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Transparencia -->
  <section class="bg-slate-50 py-20 md:py-28" data-animate>
    <div class="max-w-4xl mx-auto px-6 text-center">
      <SectionTitle
        title="Nuestro compromiso con la transparencia"
        accentLine={true}
        align="center"
      />
      <div class="prose max-w-none text-slate-600 space-y-6 leading-relaxed">
        <p class="text-lg">
          La transparencia es uno de nuestros valores fundacionales fundamentales. Por eso, publicamos informes de gestión periódicos, auditorías internas de recursos y balances anuales de impacto en nuestra sección especial.
        </p>
        <p class="text-base text-slate-500">
          Cada peso donado es administrado con rigurosidad técnica para maximizar el retorno social directo en los barrios y comunidades donde intervenimos.
        </p>
        <div class="pt-6">
          <a
            href="/transparencia/"
            class="inline-flex items-center gap-1 text-sm text-action font-semibold hover:underline"
          >
            Ver Informes de Transparencia
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section class="bg-white py-20 md:py-28" data-animate>
    <div class="max-w-3xl mx-auto px-6">
      <SectionTitle
        title="Preguntas frecuentes"
        subtitle="Si tenés alguna consulta adicional sobre la donación, aquí tenés algunas respuestas rápidas."
        align="center"
      />

      <div class="space-y-4 mt-8">
        <details class="group border border-slate-200 rounded-2xl bg-white p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-colors duration-200 hover:border-slate-350">
          <summary class="flex items-center justify-between focus:outline-none">
            <h3 class="text-base font-semibold text-slate-900 pr-4">¿Puedo donar una sola vez?</h3>
            <span class="ml-1.5 flex-shrink-0 rounded-full bg-slate-50 p-1.5 text-slate-900 group-open:rotate-180 transition-transform duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-sm text-slate-600 leading-relaxed">
            Sí, por supuesto. Podés realizar una donación única mediante transferencia bancaria. No hay mínimos ni obligaciones de recurrencia en esta modalidad.
          </p>
        </details>

        <details class="group border border-slate-200 rounded-2xl bg-white p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-colors duration-200 hover:border-slate-350">
          <summary class="flex items-center justify-between focus:outline-none">
            <h3 class="text-base font-semibold text-slate-900 pr-4">¿Cómo funciona la donación mensual?</h3>
            <span class="ml-1.5 flex-shrink-0 rounded-full bg-slate-50 p-1.5 text-slate-900 group-open:rotate-180 transition-transform duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-sm text-slate-600 leading-relaxed">
            Una vez implementada la suscripción mensual (próximamente), se debitará automáticamente el monto seleccionado mes a mes de tu tarjeta o cuenta Mercado Pago. Podés cancelar o modificar tu suscripción en cualquier momento sin ningún costo ni traba burocrática.
          </p>
        </details>

        <details class="group border border-slate-200 rounded-2xl bg-white p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-colors duration-200 hover:border-slate-350">
          <summary class="flex items-center justify-between focus:outline-none">
            <h3 class="text-base font-semibold text-slate-900 pr-4">¿Las empresas o instituciones pueden donar?</h3>
            <span class="ml-1.5 flex-shrink-0 rounded-full bg-slate-50 p-1.5 text-slate-900 group-open:rotate-180 transition-transform duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-sm text-slate-600 leading-relaxed">
            Sí. Las personas jurídicas pueden realizar donaciones, auspicios institucionales o convenios específicos de cooperación social. Brindamos recibos institucionales y certificaciones formales que avalan el destino de los fondos. Por favor, comunícate con nosotros en la página de Contacto seleccionando el motivo "Quiero proponer una alianza".
          </p>
        </details>

        <details class="group border border-slate-200 rounded-2xl bg-white p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-colors duration-200 hover:border-slate-350">
          <summary class="flex items-center justify-between focus:outline-none">
            <h3 class="text-base font-semibold text-slate-900 pr-4">¿Cómo se informa el uso de las donaciones?</h3>
            <span class="ml-1.5 flex-shrink-0 rounded-full bg-slate-50 p-1.5 text-slate-900 group-open:rotate-180 transition-transform duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-sm text-slate-600 leading-relaxed">
            Publicamos en nuestra web memorias anuales y resúmenes trimestrales de actividades, indicando detalladamente cuántas familias y personas fueron asistidas, qué talleres se impartieron y cómo se distribuyeron proporcionalmente los gastos operativos y de programas.
          </p>
        </details>

        <details class="group border border-slate-200 rounded-2xl bg-white p-6 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-colors duration-200 hover:border-slate-350">
          <summary class="flex items-center justify-between focus:outline-none">
            <h3 class="text-base font-semibold text-slate-900 pr-4">¿Puedo colaborar de otra forma si no puedo donar dinero?</h3>
            <span class="ml-1.5 flex-shrink-0 rounded-full bg-slate-50 p-1.5 text-slate-900 group-open:rotate-180 transition-transform duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 text-sm text-slate-600 leading-relaxed">
            ¡Por supuesto! Podés sumarte como voluntario a nuestras campañas, colaborar con la difusión en redes sociales o donar bienes/insumos para actividades puntuales. Contactate con nosotros para coordinar tu participación cívica activa.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- 7. CTA final -->
  <section class="bg-slate-50 py-20 md:py-28 border-t border-slate-100" data-animate>
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-slate-900 tracking-tight">
        Tu aporte puede fortalecer acciones concretas
      </h2>
      <p class="text-slate-600 mt-4 max-w-xl mx-auto leading-relaxed">
        Cada aporte de la ciudadanía es el motor fundamental que impulsa nuestra libertad e igualdad en el territorio.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="/contacto/?motivo=donar"
          class="inline-flex items-center justify-center px-8 py-4 bg-action text-white text-sm font-semibold rounded-lg shadow-sm hover:bg-action-hover transition-all"
        >
          Contactar para donar
        </a>
        <a
          href="/contacto/"
          class="inline-flex items-center justify-center px-8 py-4 border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-white transition-all"
        >
          Otras formas de ayudar
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
